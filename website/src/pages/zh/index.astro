---
import LandingPage from '../../components/LandingPage.astro'
import { defaultOgImage, localizedAlternates, localeKeywords } from '../../data/seo'
import MarketingLayout from '../../layouts/MarketingLayout.astro'
import { siteContent } from '../../data/site'

const content = siteContent.zh
---

<MarketingLayout
  lang="zh"
  title={content.title}
  description={content.description}
  canonicalPath="/zh/"
  keywords={localeKeywords.zh}
  alternates={localizedAlternates('/en/', '/zh/')}
  ogImagePath={defaultOgImage.path}
  ogImageAlt={defaultOgImage.alt.zh}
  includeSoftwareSchema
>
  <LandingPage locale="zh" content={content} />
</MarketingLayout>
