---
import Icon from './Icon.astro'
import type { SiteLocaleContent } from '../data/site'
import { repoUrl } from '../data/site'

type Locale = 'en' | 'zh'

interface Props {
  locale: Locale
  content: SiteLocaleContent
}

interface NavLink {
  label: string
  href: string
}

interface LegalLink {
  label: string
  href: string
}

interface FeatureCard {
  icon: string
  title: string
  body: string
  chips: string[]
  cta: string
  metricsLabel: string
  metricsId: string
}

interface DownloadOption {
  label: string
  href: string
}

interface LandingCopy {
  nav: NavLink[]
  heroStatus: string
  heroTitle: string
  heroLead: string
  primaryCta: string
  primaryCtaHref: string
  secondaryCta: string
  secondaryCtaHref: string
  integrationLabel: string
  integrations: string[]
  demoLabel: string
  demoFrameLabel: string
  demoTitle: string
  demoLead: string
  demoCta: string
  demoCaption: string
  featuresTitle: string
  featuresLead: string
  featureCards: FeatureCard[]
  detailLabel: string
  detailTitle: string
  detailAccent: string
  detailLead: string
  detailPoints: Array<{ title: string; body: string }>
  ctaTitle: string
  ctaLead: string
  ctaPrimary: string
  ctaSecondary: string
  footerMeta: string
  footerTagline: string
  aboutLabel: string
  aboutKicker: string
  aboutTitle: string
  aboutLead: string
  aboutAuthorLabel: string
  aboutCloseLabel: string
  footerLinks: LegalLink[]
}

const { locale } = Astro.props as Props
const heroImage = '/screens/devcue-one-hero.jpg'
const detailImage = '/screens/devcue-one-detail.svg'
const downloadBaseUrl = 'https://d.devcue.one/DevCueOne'
const bilibiliEmbedUrl =
  'https://player.bilibili.com/player.html?isOutside=true&aid=116304593819654&bvid=BV1oJXVBhESc&cid=37035835777&p=1'
const bilibiliPageUrl =
  'https://www.bilibili.com/video/BV1oJXVBhESc/?share_source=copy_web&vd_source=54186efa4ddd36c2c793ae694ef28b7f'
const releaseVersion = '0.4.1'
const macArm64Url = `${downloadBaseUrl}/DevCue.One-${releaseVersion}-mac-arm64.dmg`
const macX64Url = `${downloadBaseUrl}/DevCue.One-${releaseVersion}-mac-x64.dmg`
const authorXUrl = 'https://x.com/fukui_wuzhi'
const authorGithubUrl = 'https://github.com/wzfukui'
const localeLinks = [
  { code: 'en', label: 'EN', href: '/en/' },
  { code: 'zh', label: '中文', href: '/zh/' }
] as const
const downloadOptionsByLocale: Record<Locale, DownloadOption[]> = {
  en: [
    { label: 'Download for Apple Silicon', href: macArm64Url },
    { label: 'Download for Intel Mac', href: macX64Url }
  ],
  zh: [
    { label: '下载 Apple 芯片版', href: macArm64Url },
    { label: '下载 Intel 版', href: macX64Url }
  ]
}
const releaseNoteByLocale: Record<Locale, string> = {
  en: `DMG files hosted on R2. Version ${releaseVersion}.`,
  zh: `DMG 文件已托管到 R2。版本 ${releaseVersion}。`
}
