<script is:inline>
  const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'))
  const sectionIds = navLinks
    .map((link) => link.getAttribute('href'))
    .filter((href) => href && href.startsWith('#'))
    .map((href) => href.slice(1))

  const setActiveLink = (targetHash) => {
    navLinks.forEach((link) => {
      const isActive = link.getAttribute('href') === targetHash
      link.classList.toggle('border-b-2', isActive)
      link.classList.toggle('border-[#071a25]', isActive)
      link.classList.toggle('dark:border-[#e3e2e0]', isActive)
      link.classList.toggle('pb-1', isActive)
      link.classList.toggle('text-[#071a25]', isActive)
      link.classList.toggle('dark:text-white', isActive)
      link.classList.toggle('text-[#5f6368]', !isActive)
      link.classList.toggle('dark:text-[#9aa0a6]', !isActive)
    })
  }

  const syncActiveLink = () => {
    const fromHash = window.location.hash
    if (fromHash && sectionIds.includes(fromHash.slice(1))) {
      setActiveLink(fromHash)
      return
    }

    const marker = window.scrollY + window.innerHeight * 0.35
    let current = '#overview'

    sectionIds.forEach((id) => {
      const section = document.getElementById(id)
      if (section && section.offsetTop <= marker) {
        current = `#${id}`
      }
    })

    setActiveLink(current)
  }

  syncActiveLink()
  window.addEventListener('hashchange', syncActiveLink)
  window.addEventListener('scroll', syncActiveLink, { passive: true })

  const aboutModal = document.querySelector('[data-about-modal]')
  const aboutBackdrop = document.querySelector('[data-about-backdrop]')
  const aboutPanel = document.querySelector('[data-about-panel]')
  const aboutOpeners = Array.from(document.querySelectorAll('[data-about-open]'))
  const aboutClosers = Array.from(document.querySelectorAll('[data-about-close]'))
  let aboutHideTimer

  const showAboutModal = (event) => {
    if (!aboutModal || !aboutBackdrop || !aboutPanel) return
    if (event?.currentTarget instanceof HTMLElement) {
      aboutModal.dataset.lastTrigger = 'footer'
    }
    window.clearTimeout(aboutHideTimer)
    aboutModal.classList.remove('hidden')
    aboutModal.classList.remove('pointer-events-none')
    aboutModal.setAttribute('aria-hidden', 'false')
    document.body.classList.add('overflow-hidden')
    aboutBackdrop.classList.remove('opacity-0')
    aboutBackdrop.classList.add('opacity-100')
    aboutPanel.classList.remove('translate-y-4', 'scale-[0.98]', 'opacity-0')
    aboutPanel.classList.add('translate-y-0', 'scale-100', 'opacity-100')
  }

  const hideAboutModal = () => {
    if (!aboutModal || !aboutBackdrop || !aboutPanel) return
    aboutBackdrop.classList.remove('opacity-100')
    aboutBackdrop.classList.add('opacity-0')
    aboutPanel.classList.remove('translate-y-0', 'scale-100', 'opacity-100')
    aboutPanel.classList.add('translate-y-4', 'scale-[0.98]', 'opacity-0')
    document.body.classList.remove('overflow-hidden')
    aboutModal.setAttribute('aria-hidden', 'true')
    aboutHideTimer = window.setTimeout(() => {
      aboutModal.classList.add('hidden')
      aboutModal.classList.add('pointer-events-none')
    }, 220)
  }

  aboutOpeners.forEach((button) => button.addEventListener('click', showAboutModal))
  aboutClosers.forEach((button) => button.addEventListener('click', hideAboutModal))
  aboutBackdrop?.addEventListener('click', hideAboutModal)
  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && aboutModal?.getAttribute('aria-hidden') === 'false') {
      hideAboutModal()
    }
  })
</script>
