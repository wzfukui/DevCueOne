const copy = copyByLocale[locale]
const downloadOptions = downloadOptionsByLocale[locale]
const releaseNote = releaseNoteByLocale[locale]
---

<div class="fixed inset-0 z-0 pointer-events-none textured-bg"></div>

<header class="sticky top-0 z-50 flex w-full items-center justify-between border-b border-[#071a25]/10 bg-[#faf9f6] px-6 py-3 dark:bg-[#1a1c1a]">
  <div class="flex items-center gap-8">
    <span class="font-headline text-2xl font-semibold tracking-tighter text-[#071a25] dark:text-[#f4f3f1]">DevCue One</span>
    <nav class="hidden items-center gap-6 md:flex">
      {copy.nav.map((item, index) => (
        <a
          href={item.href}
          data-nav-link
          class:list={[
            'font-label text-sm transition-colors duration-200',
            index === 0
              ? 'border-b-2 border-[#071a25] pb-1 text-[#071a25] dark:border-[#e3e2e0] dark:text-white'
              : 'text-[#5f6368] hover:text-[#071a25] dark:text-[#9aa0a6]'
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
  <div class="flex items-center gap-3">
    <nav
      class="inline-flex items-center rounded-full border border-outline-variant/40 bg-surface-container-low p-1"
      aria-label={locale === 'zh' ? '语言切换' : 'Language switch'}
    >
      {localeLinks.map((item) => (
        <a
          href={item.href}
          class:list={[
            'inline-flex min-h-11 items-center rounded-full px-4 py-2 font-mono text-xs uppercase tracking-[0.18em] transition-colors duration-200 md:min-h-0 md:px-3 md:py-1.5 md:text-[10px] md:tracking-[0.2em]',
            item.code === locale
              ? 'bg-primary text-on-primary'
              : 'text-[#5f6368] hover:text-[#071a25] dark:text-[#9aa0a6]'
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a
      href={repoUrl}
      target="_blank"
      rel="noreferrer"
      class="group inline-flex h-11 w-11 items-center justify-center rounded-full bg-surface-container-low transition-colors duration-200 hover:bg-surface-container-high"
      aria-label="GitHub repository"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 fill-[#071a25]">
        <path d="M12 .5C5.73.5.75 5.48.75 11.75c0 5.02 3.25 9.28 7.76 10.79.57.1.78-.25.78-.55 0-.27-.01-.99-.02-1.94-3.16.69-3.83-1.52-3.83-1.52-.52-1.31-1.27-1.66-1.27-1.66-1.04-.71.08-.7.08-.7 1.14.08 1.75 1.17 1.75 1.17 1.02 1.73 2.66 1.23 3.31.94.1-.73.4-1.23.72-1.51-2.52-.29-5.17-1.26-5.17-5.58 0-1.23.44-2.23 1.17-3.02-.12-.29-.5-1.46.11-3.04 0 0 .95-.3 3.13 1.15a10.9 10.9 0 0 1 5.7 0c2.18-1.45 3.13-1.15 3.13-1.15.61 1.58.23 2.75.11 3.04.73.79 1.17 1.79 1.17 3.02 0 4.33-2.66 5.29-5.2 5.57.41.35.77 1.04.77 2.09 0 1.51-.01 2.73-.01 3.1 0 .3.21.66.79.55 4.5-1.52 7.74-5.77 7.74-10.79C23.25 5.48 18.27.5 12 .5Z" />
      </svg>
    </a>
  </div>
</header>

<main class="relative z-10">
  <section class="relative overflow-hidden px-6 pb-32 pt-24" id="overview">
    <div class="pointer-events-none absolute right-0 top-0 -mr-48 -mt-24 h-[600px] w-[600px] rounded-full bg-secondary-container/10 blur-[120px]"></div>
    <div class="mx-auto max-w-7xl lg:grid lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:gap-x-16 lg:gap-y-10">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-surface-container-high px-3 py-1 font-mono text-[10px] uppercase tracking-[0.2em] text-secondary">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-secondary opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-secondary"></span>
          </span>
          {copy.heroStatus}
        </div>
        <h1 class="max-w-xl font-headline leading-[1.05] tracking-tight text-primary text-display-lg" style="font-size: clamp(3rem, 8vw, 4.5rem);">
          {copy.heroTitle}
        </h1>
        <p class="max-w-lg font-body text-lg leading-relaxed text-on-surface-variant">
          {copy.heroLead}
        </p>
      </div>

      <div class="relative mt-12 lg:mt-0 lg:self-end">
        <div class="aspect-[1800/1065] overflow-hidden border border-outline-variant/10 shadow-2xl shadow-primary/5">
          <img
            src={heroImage}
            alt="DevCue One desktop screenshot"
            data-alt="DevCueOne local client screenshot showing multi-session voice-driven development workspace"
            class="h-full w-full object-contain object-top"
          />
        </div>
      </div>

      <div class="pt-12 lg:col-start-1 lg:pt-0">
        <div class="flex flex-wrap gap-4 pt-4">
          <a
            href={copy.primaryCtaHref}
            class="group flex items-center gap-3 rounded-lg bg-primary px-8 py-4 font-label font-medium text-on-primary transition-transform hover:scale-[0.98]"
          >
            {copy.primaryCta}
            <Icon name="arrow_forward" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
        <div class="flex items-center gap-8 border-t border-outline-variant/10 pt-8">
          <div>
            <span class="mb-1 block font-mono text-[10px] uppercase tracking-widest text-outline">{copy.integrationLabel}</span>
            <div class="flex gap-4 opacity-50 grayscale transition-all duration-500 hover:grayscale-0">
              {copy.integrations.map((integration) => (
                <span class="font-headline text-lg italic text-primary">{integration}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 pb-24" id="demo">
    <div class="mx-auto max-w-7xl">
      <div class="relative overflow-hidden rounded-[2rem] border border-outline-variant/20 bg-[linear-gradient(135deg,rgba(255,255,255,0.55),rgba(239,238,235,0.9))] p-6 shadow-[0_28px_100px_rgba(7,26,37,0.08)] sm:p-8 lg:grid lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1.28fr)] lg:items-start lg:gap-10 lg:p-10">
        <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,rgba(129,85,39,0.45),transparent)]"></div>
        <div class="relative space-y-6">
          <div class="inline-flex items-center gap-2 rounded-full border border-secondary/20 bg-white/70 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.24em] text-secondary">
            <span class="h-1.5 w-1.5 rounded-full bg-secondary"></span>
            {copy.demoLabel}
          </div>
          <div class="space-y-4">
            <h2 class="max-w-md font-headline text-4xl leading-[1.05] text-primary sm:text-[2.8rem]">
              {copy.demoTitle}
            </h2>
            <p class="max-w-md font-body text-base leading-7 text-on-surface-variant sm:text-lg">
              {copy.demoLead}
            </p>
          </div>
          <a
            href={bilibiliPageUrl}
            target="_blank"
            rel="noreferrer"
            class="group inline-flex min-h-11 items-center gap-3 rounded-full border border-primary/12 bg-primary px-5 py-3 font-label text-sm font-medium text-on-primary transition-transform hover:scale-[0.98]"
          >
            {copy.demoCta}
            <Icon name="open_in_new" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
          </a>
        </div>

        <div class="relative mt-10 lg:mt-0">
          <div class="pointer-events-none absolute inset-0 scale-[1.02] rounded-[1.6rem] bg-[radial-gradient(circle_at_top_right,rgba(246,187,132,0.24),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(79,97,109,0.18),transparent_42%)] blur-xl"></div>
          <div class="relative overflow-hidden rounded-[1.6rem] border border-primary/12 bg-[#0b1218] shadow-[0_26px_90px_rgba(7,26,37,0.2)]">
            <div class="flex items-center justify-between border-b border-white/8 bg-[#111b23] px-4 py-3 text-[#d8e5eb]">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-[#f6bb84]"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#d2e5f4]/70"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#7fb5c5]/70"></span>
              </div>
              <span class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#9db0bb]">{copy.demoFrameLabel}</span>
            </div>
            <div class="aspect-video bg-[#0b1218]">
              <iframe
                src={bilibiliEmbedUrl}
                title="DevCue One product demo on Bilibili"
                loading="lazy"
                allowfullscreen
                class="h-full w-full"
              ></iframe>
            </div>
          </div>
          <p class="mt-4 max-w-2xl font-mono text-[10px] uppercase tracking-[0.24em] text-outline">
            {copy.demoCaption}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface-container-low px-6 py-32" id="features">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto mb-20 max-w-2xl text-center">
        <h2 class="mb-6 font-headline text-4xl text-primary">{copy.featuresTitle}</h2>
        <p class="font-body text-on-surface-variant">{copy.featuresLead}</p>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-12">
        <div class="group flex min-h-[480px] flex-col justify-between rounded-xl bg-surface p-12 transition-all duration-500 hover:bg-surface-container-high md:col-span-7">
          <div>
            <Icon name={copy.featureCards[0].icon} class="mb-8 h-10 w-10 text-secondary" />
            <h3 class="mb-4 font-headline text-3xl text-primary">{copy.featureCards[0].title}</h3>
            <p class="max-w-md font-body leading-relaxed text-on-surface-variant">
              {copy.featureCards[0].body}
            </p>
          </div>
          <div class="mt-12 flex gap-2">
            {copy.featureCards[0].chips.map((chip) => (
              <div class="rounded-md border border-outline-variant/10 bg-surface-container-lowest px-4 py-2 font-mono text-xs">{chip}</div>
            ))}
          </div>
        </div>

