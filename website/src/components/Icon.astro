---
interface Props {
  name: string
  class?: string
}

const { name, class: className = '' } = Astro.props as Props
---

{
  name === 'arrow_forward' && (
    <svg viewBox="0 0 24 24" class={className} aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.9">
      <path d="M5 12h14" />
      <path d="m13 6 6 6-6 6" />
    </svg>
  )
}
{
  name === 'arrow_back' && (
    <svg viewBox="0 0 24 24" class={className} aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.9">
      <path d="M19 12H5" />
      <path d="m11 18-6-6 6-6" />
    </svg>
  )
}
{
  name === 'team_dashboard' && (
    <svg viewBox="0 0 24 24" class={className} aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7">
      <rect x="3.5" y="4" width="8" height="6.5" rx="1.5" />
      <rect x="12.5" y="4" width="8" height="10" rx="1.5" />
      <rect x="3.5" y="11.5" width="8" height="8.5" rx="1.5" />
      <rect x="12.5" y="15" width="8" height="5" rx="1.5" />
    </svg>
  )
}
{
  name === 'construction' && (
    <svg viewBox="0 0 24 24" class={className} aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7">
      <path d="m14.5 4.5 5 5" />
      <path d="m13 6 5 5" />
      <path d="m4.5 19.5 8.5-8.5" />
      <path d="m10.5 4.5-6 6" />
      <path d="m8 7 4 4" />
      <path d="m14 12 5.5 5.5" />
    </svg>
  )
}
{
  name === 'inventory_2' && (
    <svg viewBox="0 0 24 24" class={className} aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7">
      <path d="M4 8.5 12 4l8 4.5" />
      <path d="M4 8.5V18l8 4 8-4V8.5" />
      <path d="M12 22V12" />
      <path d="M8.5 10.5h7" />
    </svg>
  )
}
{
  name === 'monitoring' && (
    <svg viewBox="0 0 24 24" class={className} aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7">
      <path d="M4 19.5h16" />
      <path d="M6 16V9" />
      <path d="M11 16V5" />
      <path d="M16 16v-4" />
      <path d="M21 16V7" />
    </svg>
  )
}
{
  name === 'open_in_new' && (
    <svg viewBox="0 0 24 24" class={className} aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.9">
      <path d="M14 5h5v5" />
      <path d="m10 14 9-9" />
      <path d="M19 14v5H5V5h5" />
    </svg>
  )
}
{
  name === 'check_circle' && (
    <svg viewBox="0 0 24 24" class={className} aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.9">
      <circle cx="12" cy="12" r="8.5" />
      <path d="m8.8 12.2 2.1 2.2 4.4-4.8" />
    </svg>
  )
}
{
  name === 'github_mark' && (
    <svg viewBox="0 0 24 24" class={className} aria-hidden="true" fill="currentColor">
