{
  name === 'x_mark' && (
    <svg viewBox="0 0 24 24" class={className} aria-hidden="true" fill="currentColor">
      <path d="M18.9 2.25h3.19l-6.97 7.96 8.2 11.54h-6.42l-5.02-6.98-6.11 6.98H2.56l7.45-8.51L2.15 2.25h6.58l4.53 6.4 5.64-6.4Zm-1.13 17.57h1.77L7.77 4.08H5.87l11.9 15.74Z" />
    </svg>
