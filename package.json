{
  "name": "devcueone",
  "productName": "DevCueOne",
  "private": true,
  "version": "0.4.5",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"vite\" \"wait-on tcp:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 ./node_modules/.bin/electron electron/main.mjs\"",
    "build": "tsc -b && vite build",
    "ci:validate": "npm run lint && npm test && npm run build",
    "lint": "eslint .",
    "package:dir": "node scripts/release-build.mjs --dir",
    "package:linux": "node scripts/release-build.mjs --linux",
    "package:mac": "node scripts/release-build.mjs --mac",
    "release:mac:local": "bash ./scripts/release-macos-local.sh",
    "release:mac:local:arm64": "bash ./scripts/release-macos-local.sh --arm64",
    "release:mac:local:x64": "bash ./scripts/release-macos-local.sh --x64",
    "package:mac:arm64": "node scripts/release-build.mjs --mac --arm64",
    "package:mac:x64": "node scripts/release-build.mjs --mac --x64",
    "notarize:mac:app": "node scripts/notarize-macos-app.mjs",
    "package:win": "node scripts/release-build.mjs --win",
    "test": "node --test",
    "preview": "vite preview",
    "release:local": "node scripts/release-build.mjs",
    "start": "npm run build && ./node_modules/.bin/electron electron/main.mjs"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
